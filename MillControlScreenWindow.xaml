<Window x:Class="GRBL_Lathe_Control.MillControlScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="GRBL Sender - Mill Control Screen"
        Width="1440"
        Height="960"
        MinWidth="1240"
        MinHeight="700"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111F" Offset="0"/>
            <GradientStop Color="#111E31" Offset="0.55"/>
            <GradientStop Color="#172942" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="TouchPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style x:Key="TouchSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="52"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style x:Key="TouchComboStyle" TargetType="ComboBox" BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style x:Key="TouchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="MinHeight" Value="48"/>
        </Style>

        <Style x:Key="MillJogPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,7"/>
        </Style>

        <Style x:Key="MillJogSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,7"/>
        </Style>

        <Style x:Key="MillJogComboStyle" TargetType="ComboBox" BasedOn="{StaticResource InputComboBoxStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style x:Key="MillJogTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="MinHeight" Value="40"/>
        </Style>

        <Style x:Key="CompactTouchPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style x:Key="CompactTouchSecondaryButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinHeight" Value="42"/>
            <Setter Property="MinWidth" Value="76"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="14,8"/>
        </Style>

        <Style x:Key="CompactTouchTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputTextBoxStyle}">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="MinHeight" Value="42"/>
        </Style>

        <Style x:Key="LargeDroValueStyle" TargetType="TextBlock" BasedOn="{StaticResource AxisValueStyle}">
            <Setter Property="FontSize" Value="44"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Mill Control Screen" Style="{StaticResource SectionTitleStyle}" FontSize="28"/>
                    <TextBlock Text="Touch-first DRO, 5-axis jog controls, work offsets, spindle control, and program controls."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Connection" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock Text="{Binding ConnectionStatus}" Style="{StaticResource BodyTextStyle}" FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <TextBlock Text="Controller State" Style="{StaticResource LabelTextStyle}"/>
                        <TextBlock Text="{Binding ControllerState}" Style="{StaticResource BodyTextStyle}" FontSize="15" FontWeight="SemiBold"/>
                    </StackPanel>
                    <StackPanel Margin="0,0,20,0">
                        <CheckBox Content="Keyboard Control"
                                  Style="{StaticResource InlineCheckBoxStyle}"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding IsKeyboardControlEnabled}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardXAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="X" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardYAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="Y" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardZAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="Z" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardAAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="A" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardBAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="B" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Home"
                            Style="{StaticResource TouchSecondaryButtonStyle}"
                            Margin="0,0,12,0"
                            Command="{Binding HomeCommand}"/>
                    <Button Content="Reset"
                            Style="{StaticResource TouchSecondaryButtonStyle}"
                            Margin="0,0,12,0"
                            Command="{Binding SoftResetCommand}"/>
                    <Button Content="Unlock"
                            Style="{StaticResource TouchSecondaryButtonStyle}"
                            Margin="0,0,12,0"
                            Command="{Binding UnlockCommand}"/>
                    <Button Content="Single Screen"
                            Style="{StaticResource TouchSecondaryButtonStyle}"
                            Margin="0"
                            Click="ReturnToSingleScreen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              x:Name="ResponsiveHost"
              SizeChanged="ResponsiveHost_SizeChanged">
            <Grid x:Name="ResponsiveContentRoot"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  RenderTransformOrigin="0,0">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ResponsiveScaleTransform"/>
                </Grid.LayoutTransform>
                <Grid.RowDefinitions>
                    <RowDefinition Height="194"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="296"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="266"/>
                </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0">
            <UniformGrid Columns="5">
                <Border Background="#0E1827" CornerRadius="18" Padding="18" Margin="0,0,10,0">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="X" Style="{StaticResource SectionTitleStyle}" FontSize="24" Margin="0,0,8,0"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Margin="0,0,0,0" VerticalAlignment="Center" Visibility="{Binding XLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="X LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Text="{Binding WorkX, StringFormat=\{0:F3\} mm}" Style="{StaticResource LargeDroValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding MachineX, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" FontSize="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0E1827" CornerRadius="18" Padding="18" Margin="0,0,10,0">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Y" Style="{StaticResource SectionTitleStyle}" FontSize="24" Margin="0,0,8,0"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Margin="0,0,0,0" VerticalAlignment="Center" Visibility="{Binding YLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Y LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Text="{Binding WorkY, StringFormat=\{0:F3\} mm}" Style="{StaticResource LargeDroValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding MachineY, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" FontSize="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0E1827" CornerRadius="18" Padding="18" Margin="0,0,10,0">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="Z" Style="{StaticResource SectionTitleStyle}" FontSize="24" Margin="0,0,8,0"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Margin="0,0,8,0" VerticalAlignment="Center" Visibility="{Binding ZLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Z LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <Border Style="{StaticResource LimitBadgeStyle}" Margin="0,0,0,0" VerticalAlignment="Center" Visibility="{Binding ProbePinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="PROBE" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="13" FontWeight="Bold"/>
                            </Border>
                        </WrapPanel>
                        <TextBlock Text="{Binding WorkZ, StringFormat=\{0:F3\} mm}" Style="{StaticResource LargeDroValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding MachineZ, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" FontSize="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0E1827" CornerRadius="18" Padding="18" Margin="0,0,10,0">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="A" Style="{StaticResource SectionTitleStyle}" FontSize="24" Margin="0,0,8,0"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding WorkA, StringFormat=\{0:F3\} deg}" Style="{StaticResource LargeDroValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding MachineA, StringFormat=Machine \{0:F3\} deg}" Style="{StaticResource BodyTextStyle}" FontSize="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Background="#0E1827" CornerRadius="18" Padding="18" Margin="0">
                    <StackPanel>
                        <WrapPanel VerticalAlignment="Center">
                            <TextBlock Text="B" Style="{StaticResource SectionTitleStyle}" FontSize="24" Margin="0,0,8,0"/>
                        </WrapPanel>
                        <TextBlock Text="{Binding WorkB, StringFormat=\{0:F3\} deg}" Style="{StaticResource LargeDroValueStyle}" Margin="0,10,0,0"/>
                        <TextBlock Text="{Binding MachineB, StringFormat=Machine \{0:F3\} deg}" Style="{StaticResource BodyTextStyle}" FontSize="16" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Manual Jog" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="X" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="20" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" Style="{StaticResource MillJogComboStyle}" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedXJogStep}"/>
                        <TextBox Grid.Column="4" Style="{StaticResource MillJogTextBoxStyle}" Margin="0" Text="{Binding XJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <UniformGrid Grid.Column="6" Rows="1" Columns="2" Margin="0,0,0,0">
                            <Button Content="-X" Style="{StaticResource MillJogSecondaryButtonStyle}" Height="48" Command="{Binding JogXNegativeCommand}"/>
                            <Button Content="+X" Style="{StaticResource MillJogPrimaryButtonStyle}" Height="48" Margin="10,0,0,0" Command="{Binding JogXPositiveCommand}"/>
                        </UniformGrid>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Y" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="20" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" Style="{StaticResource MillJogComboStyle}" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedYJogStep}"/>
                        <TextBox Grid.Column="4" Style="{StaticResource MillJogTextBoxStyle}" Margin="0" Text="{Binding YJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <UniformGrid Grid.Column="6" Rows="1" Columns="2">
                            <Button Content="-Y" Style="{StaticResource MillJogSecondaryButtonStyle}" Height="48" Command="{Binding JogYNegativeCommand}"/>
                            <Button Content="+Y" Style="{StaticResource MillJogPrimaryButtonStyle}" Height="48" Margin="10,0,0,0" Command="{Binding JogYPositiveCommand}"/>
                        </UniformGrid>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Z" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="20" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" Style="{StaticResource MillJogComboStyle}" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedZJogStep}"/>
                        <TextBox Grid.Column="4" Style="{StaticResource MillJogTextBoxStyle}" Margin="0" Text="{Binding ZJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <UniformGrid Grid.Column="6" Rows="1" Columns="2">
                            <Button Content="-Z" Style="{StaticResource MillJogSecondaryButtonStyle}" Height="48" Command="{Binding JogZNegativeCommand}"/>
                            <Button Content="+Z" Style="{StaticResource MillJogPrimaryButtonStyle}" Height="48" Margin="10,0,0,0" Command="{Binding JogZPositiveCommand}"/>
                        </UniformGrid>
                    </Grid>

                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="A" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="20" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" Style="{StaticResource MillJogComboStyle}" ItemsSource="{Binding RotaryJogSteps}" SelectedItem="{Binding SelectedAJogStep}"/>
                        <TextBox Grid.Column="4" Style="{StaticResource MillJogTextBoxStyle}" Margin="0" Text="{Binding AJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <UniformGrid Grid.Column="6" Rows="1" Columns="2">
                            <Button Content="-A" Style="{StaticResource MillJogSecondaryButtonStyle}" Height="48" Command="{Binding JogANegativeCommand}"/>
                            <Button Content="+A" Style="{StaticResource MillJogPrimaryButtonStyle}" Height="48" Margin="10,0,0,0" Command="{Binding JogAPositiveCommand}"/>
                        </UniformGrid>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="34"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="118"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="110"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="B" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="20" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2" Style="{StaticResource MillJogComboStyle}" ItemsSource="{Binding RotaryJogSteps}" SelectedItem="{Binding SelectedBJogStep}"/>
                        <TextBox Grid.Column="4" Style="{StaticResource MillJogTextBoxStyle}" Margin="0" Text="{Binding BJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <UniformGrid Grid.Column="6" Rows="1" Columns="2">
                            <Button Content="-B" Style="{StaticResource MillJogSecondaryButtonStyle}" Height="48" Command="{Binding JogBNegativeCommand}"/>
                            <Button Content="+B" Style="{StaticResource MillJogPrimaryButtonStyle}" Height="48" Margin="10,0,0,0" Command="{Binding JogBPositiveCommand}"/>
                        </UniformGrid>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Work Offsets" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    <TextBlock Grid.Row="1"
                               Text="Direct X/Y/Z/A/B work offset updates sized to stay visible on a 1080p control screen."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>

                    <Grid Grid.Row="3" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="150"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="WCS" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="2"
                                  Style="{StaticResource TouchComboStyle}"
                                  ItemsSource="{Binding WorkCoordinateSystems}"
                                  SelectedItem="{Binding SelectedWorkCoordinateSystem}"/>
                    </Grid>

                    <Grid Grid.Row="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Work X" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource CompactTouchTextBoxStyle}"
                                 Text="{Binding WorkXInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4"
                                Content="Set X"
                                Style="{StaticResource CompactTouchPrimaryButtonStyle}"
                                Command="{Binding SetWorkXCommand}"/>
                        <Button Grid.Column="6"
                                Content="Zero X"
                                Style="{StaticResource CompactTouchSecondaryButtonStyle}"
                                Command="{Binding ZeroXCommand}"/>
                    </Grid>

                    <Grid Grid.Row="7">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Work Y" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource CompactTouchTextBoxStyle}"
                                 Text="{Binding WorkYInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4"
                                Content="Set Y"
                                Style="{StaticResource CompactTouchPrimaryButtonStyle}"
                                Command="{Binding SetWorkYCommand}"/>
                        <Button Grid.Column="6"
                                Content="Zero Y"
                                Style="{StaticResource CompactTouchSecondaryButtonStyle}"
                                Command="{Binding ZeroYCommand}"/>
                    </Grid>

                    <Grid Grid.Row="9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Work Z" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource CompactTouchTextBoxStyle}"
                                 Text="{Binding WorkZInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4"
                                Content="Set Z"
                                Style="{StaticResource CompactTouchPrimaryButtonStyle}"
                                Command="{Binding SetWorkZCommand}"/>
                        <Button Grid.Column="6"
                                Content="Zero Z"
                                Style="{StaticResource CompactTouchSecondaryButtonStyle}"
                                Command="{Binding ZeroZCommand}"/>
                    </Grid>

                    <Grid Grid.Row="11" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Work A" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource CompactTouchTextBoxStyle}"
                                 Text="{Binding WorkAInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4"
                                Content="Set A"
                                Style="{StaticResource CompactTouchPrimaryButtonStyle}"
                                Command="{Binding SetWorkACommand}"/>
                        <Button Grid.Column="6"
                                Content="Zero A"
                                Style="{StaticResource CompactTouchSecondaryButtonStyle}"
                                Command="{Binding ZeroACommand}"/>
                    </Grid>

                    <Grid Grid.Row="13" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Work B" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2"
                                 Style="{StaticResource CompactTouchTextBoxStyle}"
                                 Text="{Binding WorkBInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="4"
                                Content="Set B"
                                Style="{StaticResource CompactTouchPrimaryButtonStyle}"
                                Command="{Binding SetWorkBCommand}"/>
                        <Button Grid.Column="6"
                                Content="Zero B"
                                Style="{StaticResource CompactTouchSecondaryButtonStyle}"
                                Command="{Binding ZeroBCommand}"/>
                    </Grid>
                </Grid>
                </ScrollViewer>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="18"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Spindle Control" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                    <Grid Grid.Row="1" Margin="0,12,0,10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Speed (S)" Style="{StaticResource LabelTextStyle}" Margin="0"/>
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SelectedSpindleSpeedText}"
                                       Style="{StaticResource BodyTextStyle}"
                                       FontFamily="Consolas"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Margin="12,0,0,0"/>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="12"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="Max S" Style="{StaticResource LabelTextStyle}" VerticalAlignment="Center" Margin="0"/>
                            <TextBox Grid.Column="2"
                                     Style="{StaticResource TouchTextBoxStyle}"
                                     Margin="0"
                                     Text="{Binding SpindleMaxSpeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="4"
                                    Content="Set Max"
                                    Style="{StaticResource TouchSecondaryButtonStyle}"
                                    Margin="0"
                                    Command="{Binding SetSpindleMaxSpeedCommand}"/>
                        </Grid>
                    </Grid>

                    <Slider Grid.Row="2"
                            Minimum="0"
                            Maximum="{Binding SpindleMaxSpeed}"
                            TickFrequency="25"
                            SmallChange="1"
                            LargeChange="25"
                            Margin="0,0,0,10"
                            Style="{StaticResource TouchSliderStyle}"
                            IsEnabled="{Binding CanManualSpindleControl}"
                            Value="{Binding SelectedSpindleSpeed}"/>
                    <UniformGrid Grid.Row="3" Rows="1" Columns="2">
                        <Button Content="Start / Update" Style="{StaticResource TouchPrimaryButtonStyle}" Height="56" Command="{Binding ApplySpindleSpeedCommand}"/>
                        <Button Content="Stop Spindle" Style="{StaticResource TouchSecondaryButtonStyle}" Height="56" Margin="12,0,0,0" Command="{Binding StopSpindleCommand}"/>
                    </UniformGrid>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardBorderStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Program / Feed" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                    <TextBlock Grid.Row="1" Text="{Binding ProgramSummaryText}" Style="{StaticResource LabelTextStyle}" Margin="0,8,0,10" TextWrapping="Wrap"/>
                    <UniformGrid Grid.Row="2" Rows="1" Columns="3" Margin="0,0,0,0">
                        <Button Content="Run" Style="{StaticResource TouchPrimaryButtonStyle}" Height="56" Command="{Binding StartProgramCommand}"/>
                        <Button Content="{Binding PauseResumeLabel}" Style="{StaticResource TouchSecondaryButtonStyle}" Height="56" Margin="12,0,0,0" Command="{Binding PauseResumeProgramCommand}"/>
                        <Button Content="Stop" Style="{StaticResource TouchSecondaryButtonStyle}" Height="56" Margin="12,0,0,0" Command="{Binding StopProgramCommand}"/>
                    </UniformGrid>
                    <Grid Grid.Row="4" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Feed Override" Style="{StaticResource LabelTextStyle}" Margin="0"/>
                        <TextBlock Grid.Column="1" Text="{Binding FeedOverrideText}" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" FontWeight="SemiBold" Margin="12,0,0,0"/>
                    </Grid>
                    <Slider Grid.Row="5"
                            Minimum="25"
                            Maximum="200"
                            TickFrequency="5"
                            SmallChange="1"
                            LargeChange="10"
                            Style="{StaticResource FeedOverrideSliderStyle}"
                            IsEnabled="{Binding IsConnected}"
                            Value="{Binding FeedOverridePercent}"/>
                </Grid>
            </Border>
        </Grid>
            </Grid>
        </Grid>
    </Grid>
</Window>
