<UserControl x:Class="GRBL_Lathe_Control.Controls.MillDataPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="700">
    <TabControl Style="{StaticResource PreviewTabControlStyle}"
                BorderThickness="0">
        <TabItem Header="Preview" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tool Path Preview" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Plan view of the loaded program in the mill's X/Y plane. The live yellow marker tracks the current work position."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#0E1827"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Preview Reference" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding WorkX, StringFormat=X {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="{Binding WorkY, StringFormat=Y {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <controls:ToolPathPreviewControl Grid.Row="2"
                                                     Segments="{Binding ToolPathSegments}"
                                                     CurrentHorizontal="{Binding PreviewHorizontalPosition}"
                                                     CurrentVertical="{Binding PreviewVerticalPosition}"
                                                     HorizontalAxisLabel="{Binding PreviewHorizontalAxisLabel}"
                                                     VerticalAxisLabel="{Binding PreviewVerticalAxisLabel}"/>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Tool Probe" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tool Probe" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                        <TextBlock Text="Zero the work with the reference tool first. Then use Calibrate Plate Reference to move to the fixed tool-change plate and probe it automatically. Later tool probes use the difference between the saved reference touch and the newly touched tool to keep work Z aligned."
                                   Style="{StaticResource LabelTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tool Change X (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeXInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Tool Change Y (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeYInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Capture Current X / Y"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,12"
                                    ToolTip="Store the current machine X and Y as the tool-change position."
                                    Command="{Binding CaptureToolChangePositionCommand}"/>

                            <TextBlock Text="Safe Z (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeSafeZInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="Probe Start Z (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeStartZInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Content="Capture Current Z"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0"
                                    ToolTip="Store the current machine Z as the probe start Z position."
                                    Command="{Binding CaptureProbeStartZCommand}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Probe Travel (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeTravelInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Probe Feed (mm/min)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeFeedInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Fine Probe Feed (mm/min)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeFineFeedInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Pull-Off (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeRetractInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="{Binding MillToolProbeStatusText}"
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="Tip: the probe cycle now rapids to safe Z, moves to tool-change X/Y, rapids down to Probe Start Z, probes at the coarse feed, pulls off, then probes again at the fine feed. The second touch point is the one used for calibration and tool-length updates."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4">
                        <WrapPanel>
                            <Button Content="Go Safe Z"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,12,12"
                                    ToolTip="Raise to the configured machine safe Z."
                                    Command="{Binding GoSafeZCommand}"/>
                            <Button Content="Go To Tool Change"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,12,12"
                                    ToolTip="Raise to safe Z, then move to the configured machine X/Y tool-change plate position."
                                    Command="{Binding GoToToolChangeCommand}"/>
                            <Button Content="Go To X / Y Zero"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,0,12"
                                    ToolTip="Move in work coordinates to X0 Y0 using the current jog feeds."
                                    Command="{Binding GoToXYZeroCommand}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <Button Content="Calibrate Plate Reference"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,0,12,0"
                                    ToolTip="Move to the tool-change plate, run the two-stage reference-tool probe cycle, and save the final fine-touch machine Z as the master reference."
                                    Command="{Binding CalibrateToolProbePlateCommand}"/>
                            <Button Content="Run Tool Probe"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0"
                                    ToolTip="Move to the tool-change plate, run the two-stage tool probe, and adjust work Z from the stored fine-touch reference."
                                    Command="{Binding RunToolProbeCommand}"/>
                        </WrapPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
