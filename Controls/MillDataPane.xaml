<UserControl x:Class="GRBL_Lathe_Control.Controls.MillDataPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="700">
    <TabControl Style="{StaticResource PreviewTabControlStyle}"
                BorderThickness="0">
        <TabItem Header="Preview" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tool Path Preview" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Plan view of the loaded program in the mill's X/Y plane. The live yellow marker tracks the current work position."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#0E1827"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Preview Reference" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding WorkX, StringFormat=X {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="{Binding WorkY, StringFormat=Y {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <controls:ToolPathPreviewControl Grid.Row="2"
                                                     Segments="{Binding ToolPathSegments}"
                                                     CurrentHorizontal="{Binding PreviewHorizontalPosition}"
                                                     CurrentVertical="{Binding PreviewVerticalPosition}"
                                                     HorizontalAxisLabel="{Binding PreviewHorizontalAxisLabel}"
                                                     VerticalAxisLabel="{Binding PreviewVerticalAxisLabel}"/>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Tool Probe" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tool Probe" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                        <TextBlock Text="The mill probe cycle moves to the configured machine-coordinate tool-change X/Y position, drops to the safe machine Z, probes downward onto the touch plate, then sets work Z from the configured touch-plate thickness. You can calibrate that thickness from a reference tool after you have already found work Z zero on the part."
                                   Style="{StaticResource LabelTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Tool Change X (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeXInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Tool Change Y (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeYInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Safe Z (Machine)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ToolChangeSafeZInput, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Probe Travel (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeTravelInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Probe Feed (mm/min)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeFeedInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Retract (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0,0,0,10"
                                     Text="{Binding ProbeRetractInput, UpdateSourceTrigger=PropertyChanged}"/>

                            <TextBlock Text="Touch Plate Thickness (mm)" Style="{StaticResource LabelTextStyle}"/>
                            <TextBox Style="{StaticResource InputTextBoxStyle}"
                                     Margin="0"
                                     Text="{Binding TouchPlateThicknessInput, UpdateSourceTrigger=PropertyChanged}"/>
                            <TextBlock Text="After the reference tool is zeroed on the work, touch the top of the plate and use the calibrate button to capture that displayed work Z."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="4" Orientation="Horizontal">
                        <Button Content="Calibrate Plate From Current Z"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="0,0,12,0"
                                ToolTip="Capture the current displayed work Z as the touch-plate thickness after zeroing with the reference tool."
                                Command="{Binding CalibrateTouchPlateThicknessCommand}"/>
                        <Button Content="Run Tool Probe"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0"
                                ToolTip="Move to the tool-change position, probe down to the touch plate, then set work Z from the touch-plate thickness."
                                Command="{Binding RunToolProbeCommand}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
