<UserControl x:Class="GRBL_Lathe_Control.Controls.ToolDataPane"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
             mc:Ignorable="d"
             d:DesignHeight="800"
             d:DesignWidth="700">
    <TabControl Style="{StaticResource PreviewTabControlStyle}"
                BorderThickness="0">
        <TabItem Header="Preview" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="Tool Path Preview" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Plan view of the loaded program in the lathe's X/Z plane. The live yellow marker tracks the current work position."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                        </StackPanel>

                        <Border Grid.Column="1"
                                Background="#0E1827"
                                BorderBrush="{StaticResource CardBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="14"
                                Padding="12"
                                HorizontalAlignment="Right">
                            <StackPanel>
                                <TextBlock Text="Preview Reference" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding WorkX, StringFormat=X {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                                <TextBlock Text="{Binding WorkZ, StringFormat=Z {0:F3} mm}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <controls:ToolPathPreviewControl Grid.Row="2"
                                                     Segments="{Binding ToolPathSegments}"
                                                     CurrentX="{Binding WorkX}"
                                                     CurrentZ="{Binding WorkZ}"/>
                </Grid>
            </Border>
        </TabItem>

        <TabItem Header="Tool Offsets" Style="{StaticResource PreviewTabItemStyle}">
            <Border Style="{StaticResource CardBorderStyle}" Margin="0,8,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Tool Offsets" Style="{StaticResource SectionTitleStyle}" FontSize="22"/>
                            <TextBlock Text="Add tools manually or let the program load create missing tool rows. Set stores the current work X/Z difference from the master tool, and Use shifts the work zero to match the selected tool."
                                       Style="{StaticResource LabelTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="160"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Margin="0"
                                 ToolTip="Enter a tool number to add a new offset row."
                                 Text="{Binding NewToolNumberInput, UpdateSourceTrigger=PropertyChanged}"/>
                        <Button Grid.Column="2"
                                Content="Add Tool"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="0"
                                ToolTip="Add a new tool offset row without overwriting any existing values."
                                Command="{Binding AddToolCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding ToolOffsets}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0E1827"
                                            BorderBrush="{StaticResource CardBorderBrush}"
                                            BorderThickness="1"
                                            CornerRadius="14"
                                            Padding="14"
                                            Margin="0,0,0,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="12"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Tool" Style="{StaticResource LabelTextStyle}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding ToolNumber, StringFormat=T{0}}"
                                                           Style="{StaticResource BodyTextStyle}"
                                                           FontFamily="Consolas"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="X Offset" Style="{StaticResource LabelTextStyle}"/>
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Margin="0"
                                                         Text="{Binding XOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3">
                                                <TextBlock Text="Z Offset" Style="{StaticResource LabelTextStyle}"/>
                                                <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                         Margin="0"
                                                         Text="{Binding ZOffsetInput, UpdateSourceTrigger=PropertyChanged}"/>
                                            </StackPanel>

                                            <Button Grid.Column="5"
                                                    Content="Set"
                                                    Width="66"
                                                    Height="40"
                                                    VerticalAlignment="Bottom"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Margin="0"
                                                    ToolTip="Store the current displayed work X and Z as this tool's offset from the master tool."
                                                    Command="{Binding SetCommand}"/>

                                            <Button Grid.Column="7"
                                                    Content="Use"
                                                    Width="66"
                                                    Height="40"
                                                    VerticalAlignment="Bottom"
                                                    Style="{StaticResource PrimaryButtonStyle}"
                                                    Margin="0"
                                                    ToolTip="Shift the active work zero by this tool's stored offset from the master tool."
                                                    Command="{Binding UseCommand}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </TabItem>
    </TabControl>
</UserControl>
