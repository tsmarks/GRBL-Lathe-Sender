<Window x:Class="GRBL_Lathe_Control.MillMainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
        mc:Ignorable="d"
        Title="GRBL Sender - Mill"
        Width="1580"
        Height="980"
        MinWidth="1320"
        MinHeight="860"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111F" Offset="0"/>
            <GradientStop Color="#111E31" Offset="0.55"/>
            <GradientStop Color="#172942" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Window.Resources>
        <Style x:Key="MillDroValueStyle" TargetType="TextBlock" BasedOn="{StaticResource AxisValueStyle}">
            <Setter Property="FontSize" Value="34"/>
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="GRBL Sender" Style="{StaticResource SectionTitleStyle}" FontSize="24"/>
                    <TextBlock Text="Shared GRBL core with a mill-specific 5-axis UI, XY preview, touch-friendly jog controls, and a tool probe workflow."
                               Style="{StaticResource LabelTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="COM Port" Style="{StaticResource LabelTextStyle}"/>
                        <ComboBox Width="120"
                                  Style="{StaticResource InputComboBoxStyle}"
                                  ItemsSource="{Binding AvailablePorts}"
                                  SelectedItem="{Binding SelectedPort}"/>
                    </StackPanel>

                    <Button Content="Refresh"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,12,8"
                            Command="{Binding RefreshPortsCommand}"/>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Text="Baud" Style="{StaticResource LabelTextStyle}"/>
                        <TextBox Width="90"
                                 Style="{StaticResource InputTextBoxStyle}"
                                 Margin="0"
                                 Text="{Binding BaudRateInput, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <Button Content="Connect"
                            Style="{StaticResource PrimaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Command="{Binding ConnectCommand}"/>
                    <Button Content="Disconnect"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Command="{Binding DisconnectCommand}"/>
                    <Button Content="Home"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Command="{Binding HomeCommand}"/>
                    <Button Content="Reset"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,8,8"
                            Command="{Binding SoftResetCommand}"/>
                    <CheckBox Content="Keyboard Control"
                              Style="{StaticResource InlineCheckBoxStyle}"
                              VerticalAlignment="Bottom"
                              Margin="0,0,12,14"
                              IsChecked="{Binding IsKeyboardControlEnabled}"/>
                    <Button Content="Dual Screen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            VerticalAlignment="Bottom"
                            Margin="0,0,0,8"
                            Click="OpenDualScreen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource CardBorderStyle}" Margin="0">
            <StackPanel>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="{Binding KeyboardControlStatusText}" Style="{StaticResource LabelTextStyle}" Margin="0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardXAxisActive}" VerticalAlignment="Center"/>
                        <TextBlock Text="X" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardYAxisActive}" VerticalAlignment="Center"/>
                        <TextBlock Text="Y" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardZAxisActive}" VerticalAlignment="Center"/>
                        <TextBlock Text="Z" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardAAxisActive}" VerticalAlignment="Center"/>
                        <TextBlock Text="A" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                        <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardBAxisActive}" VerticalAlignment="Center"/>
                        <TextBlock Text="B" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,14,0"/>
                        <TextBlock Text="{Binding KeyboardStepText}" Style="{StaticResource LabelTextStyle}" FontFamily="Consolas" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding KeyboardFeedText}" Style="{StaticResource LabelTextStyle}" FontFamily="Consolas"/>
                    </StackPanel>
                </DockPanel>

                <UniformGrid Columns="5">
                    <Border Background="#0E1827" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="X Axis" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Visibility="{Binding XLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="X LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding WorkX, StringFormat=\{0:F3\} mm}" Style="{StaticResource MillDroValueStyle}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding MachineX, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E1827" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Y Axis" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Visibility="{Binding YLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Y LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding WorkY, StringFormat=\{0:F3\} mm}" Style="{StaticResource MillDroValueStyle}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding MachineY, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E1827" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="Z Axis" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <Border Style="{StaticResource LimitBadgeStyle}" Visibility="{Binding ZLimitPinHigh, Converter={StaticResource BoolToVisibilityConverter}}">
                                <TextBlock Text="Z LIMIT" Foreground="{StaticResource SectionTitleBrush}" FontFamily="Bahnschrift" FontSize="11" FontWeight="Bold"/>
                            </Border>
                            <TextBlock Text="{Binding WorkZ, StringFormat=\{0:F3\} mm}" Style="{StaticResource MillDroValueStyle}" Margin="0,10,0,0"/>
                            <TextBlock Text="{Binding MachineZ, StringFormat=Machine \{0:F3\} mm}" Style="{StaticResource BodyTextStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E1827" CornerRadius="14" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="A Axis" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <TextBlock Text="{Binding WorkA, StringFormat=\{0:F3\} deg}" Style="{StaticResource MillDroValueStyle}" Margin="0,20,0,0"/>
                            <TextBlock Text="{Binding MachineA, StringFormat=Machine \{0:F3\} deg}" Style="{StaticResource BodyTextStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0E1827" CornerRadius="14" Padding="14" Margin="0">
                        <StackPanel>
                            <TextBlock Text="B Axis" Style="{StaticResource SectionTitleStyle}" FontSize="16"/>
                            <TextBlock Text="{Binding WorkB, StringFormat=\{0:F3\} deg}" Style="{StaticResource MillDroValueStyle}" Margin="0,20,0,0"/>
                            <TextBlock Text="{Binding MachineB, StringFormat=Machine \{0:F3\} deg}" Style="{StaticResource BodyTextStyle}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="470"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Work Offsets" Style="{StaticResource SectionTitleStyle}"/>
                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding WorkXInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="Set X" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding SetWorkXCommand}"/>
                                <Button Grid.Column="4" Content="Zero X" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding ZeroXCommand}"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding WorkYInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="Set Y" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding SetWorkYCommand}"/>
                                <Button Grid.Column="4" Content="Zero Y" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding ZeroYCommand}"/>
                            </Grid>
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBox Grid.Column="0" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding WorkZInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="Set Z" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding SetWorkZCommand}"/>
                                <Button Grid.Column="4" Content="Zero Z" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding ZeroZCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Manual Jog" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="5-axis mill jog controls with independent steps and feeds."
                                       Style="{StaticResource LabelTextStyle}"
                                       Margin="0,8,0,14"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="X" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" Style="{StaticResource InputComboBoxStyle}" Height="40" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedXJogStep}"/>
                                <TextBox Grid.Column="4" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding XJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="6" Content="-X" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding JogXNegativeCommand}"/>
                                <Button Grid.Column="8" Content="+X" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding JogXPositiveCommand}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Y" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" Style="{StaticResource InputComboBoxStyle}" Height="40" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedYJogStep}"/>
                                <TextBox Grid.Column="4" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding YJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="6" Content="-Y" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding JogYNegativeCommand}"/>
                                <Button Grid.Column="8" Content="+Y" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding JogYPositiveCommand}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Z" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" Style="{StaticResource InputComboBoxStyle}" Height="40" ItemsSource="{Binding LinearJogSteps}" SelectedItem="{Binding SelectedZJogStep}"/>
                                <TextBox Grid.Column="4" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding ZJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="6" Content="-Z" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding JogZNegativeCommand}"/>
                                <Button Grid.Column="8" Content="+Z" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding JogZPositiveCommand}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="A" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" Style="{StaticResource InputComboBoxStyle}" Height="40" ItemsSource="{Binding RotaryJogSteps}" SelectedItem="{Binding SelectedAJogStep}"/>
                                <TextBox Grid.Column="4" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding AJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="6" Content="-A" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding JogANegativeCommand}"/>
                                <Button Grid.Column="8" Content="+A" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding JogAPositiveCommand}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="34"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="108"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="10"/>
                                    <ColumnDefinition Width="62"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="62"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="B" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="18" VerticalAlignment="Center"/>
                                <ComboBox Grid.Column="2" Style="{StaticResource InputComboBoxStyle}" Height="40" ItemsSource="{Binding RotaryJogSteps}" SelectedItem="{Binding SelectedBJogStep}"/>
                                <TextBox Grid.Column="4" Style="{StaticResource InputTextBoxStyle}" Margin="0" Text="{Binding BJogFeedInput, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="6" Content="-B" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding JogBNegativeCommand}"/>
                                <Button Grid.Column="8" Content="+B" Style="{StaticResource PrimaryButtonStyle}" Margin="0" Command="{Binding JogBPositiveCommand}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Spindle Control" Style="{StaticResource SectionTitleStyle}"/>
                            <DockPanel Margin="0,12,0,8">
                                <TextBlock Text="Speed (S)" Style="{StaticResource LabelTextStyle}" Margin="0"/>
                                <TextBlock Text="{Binding SelectedSpindleSpeedText}" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontSize="14" FontWeight="SemiBold"/>
                            </DockPanel>
                            <Slider Minimum="0" Maximum="1000" TickFrequency="25" SmallChange="1" LargeChange="25" IsEnabled="{Binding CanManualSpindleControl}" Value="{Binding SelectedSpindleSpeed}" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Start / Update" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ApplySpindleSpeedCommand}"/>
                                <Button Content="Stop Spindle" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding StopSpindleCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="Program Playback" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="{Binding ProgramSummaryText}" Style="{StaticResource LabelTextStyle}" Margin="0,10,0,8" TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding ProgramPath}" Style="{StaticResource BodyTextStyle}" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                <Button Content="Load Program" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding LoadProgramCommand}"/>
                                <Button Content="Run" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartProgramCommand}"/>
                                <Button Content="{Binding PauseResumeLabel}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PauseResumeProgramCommand}"/>
                                <Button Content="Stop" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding StopProgramCommand}"/>
                            </StackPanel>
                            <ProgressBar Height="10" Maximum="100" Value="{Binding ProgramProgressPercent, Mode=OneWay}" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding ProgramProgressText}" Style="{StaticResource BodyTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Text="Controller Log" Style="{StaticResource SectionTitleStyle}"/>
                            <ListBox ItemsSource="{Binding ControllerLog}"
                                     Height="220"
                                     Margin="0,14,0,0"
                                     Background="#0C1728"
                                     BorderBrush="{StaticResource InputBorderBrush}"
                                     BorderThickness="1"
                                     Foreground="{StaticResource ValueBrush}"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Padding="6"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <controls:MillDataPane Grid.Column="2"/>
        </Grid>
    </Grid>
</Window>
