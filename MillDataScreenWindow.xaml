<Window x:Class="GRBL_Lathe_Control.MillDataScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:GRBL_Lathe_Control.Controls"
        mc:Ignorable="d"
        Title="GRBL Sender - Mill Data Screen"
        Width="1440"
        Height="960"
        MinWidth="1200"
        MinHeight="680"
        PreviewKeyDown="Window_PreviewKeyDown"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#08111F" Offset="0"/>
            <GradientStop Color="#111E31" Offset="0.55"/>
            <GradientStop Color="#172942" Offset="1"/>
        </LinearGradientBrush>
    </Window.Background>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorderStyle}" Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Mill Data Screen" Style="{StaticResource SectionTitleStyle}" FontSize="28"/>
                    <TextBlock Text="Preview, tool probe, work offsets, connection details, and controller logs."
                               Style="{StaticResource LabelTextStyle}"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,20,0">
                        <CheckBox Content="Keyboard Control"
                                  Style="{StaticResource InlineCheckBoxStyle}"
                                  Margin="0,0,0,6"
                                  IsChecked="{Binding IsKeyboardControlEnabled}"/>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardXAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="X" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardYAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="Y" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardZAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="Z" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardAAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="A" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold" Margin="0,0,10,0"/>
                            <Ellipse Style="{StaticResource LedIndicatorStyle}" Tag="{Binding IsKeyboardBAxisActive}" VerticalAlignment="Center"/>
                            <TextBlock Text="B" Style="{StaticResource BodyTextStyle}" FontFamily="Consolas" FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Content="Single Screen"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Margin="0"
                            VerticalAlignment="Center"
                            Click="ReturnToSingleScreen_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              x:Name="ResponsiveHost"
              SizeChanged="ResponsiveHost_SizeChanged">
            <Grid x:Name="ResponsiveContentRoot"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  RenderTransformOrigin="0,0">
                <Grid.LayoutTransform>
                    <ScaleTransform x:Name="ResponsiveScaleTransform"/>
                </Grid.LayoutTransform>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.35*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="0.9*"/>
                </Grid.ColumnDefinitions>

                <controls:MillDataPane Grid.Column="0"/>

                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Connection" Style="{StaticResource SectionTitleStyle}"/>
                                <Grid Margin="0,14,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="COM Port" Style="{StaticResource LabelTextStyle}"/>
                                        <ComboBox Style="{StaticResource InputComboBoxStyle}"
                                                  ItemsSource="{Binding AvailablePorts}"
                                                  SelectedItem="{Binding SelectedPort}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Baud" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBox Style="{StaticResource InputTextBoxStyle}"
                                                 Margin="0"
                                                 Text="{Binding BaudRateInput, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Bottom">
                                        <Button Content="Refresh" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshPortsCommand}"/>
                                        <Button Content="Connect" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConnectCommand}"/>
                                        <Button Content="Disconnect" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DisconnectCommand}"/>
                                        <Button Content="Home" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding HomeCommand}"/>
                                        <Button Content="Reset" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding SoftResetCommand}"/>
                                    </StackPanel>
                                </Grid>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="12"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Connection Status" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Text="{Binding ConnectionStatus}" Style="{StaticResource BodyTextStyle}" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Controller State" Style="{StaticResource LabelTextStyle}"/>
                                        <TextBlock Text="{Binding ControllerState}" Style="{StaticResource BodyTextStyle}" FontSize="14" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}">
                            <StackPanel>
                                <TextBlock Text="Program" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding ProgramSummaryText}" Style="{StaticResource LabelTextStyle}" Margin="0,10,0,8" TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding ProgramPath}" Style="{StaticResource BodyTextStyle}" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>

                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Load Program" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding LoadProgramCommand}"/>
                                    <Button Content="Run" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartProgramCommand}"/>
                                    <Button Content="{Binding PauseResumeLabel}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding PauseResumeProgramCommand}"/>
                                    <Button Content="Stop" Style="{StaticResource SecondaryButtonStyle}" Margin="0" Command="{Binding StopProgramCommand}"/>
                                </StackPanel>

                                <ProgressBar Height="10"
                                             Maximum="100"
                                             Value="{Binding ProgramProgressPercent, Mode=OneWay}"
                                             Margin="0,14,0,10"/>
                                <TextBlock Text="{Binding ProgramProgressText}" Style="{StaticResource BodyTextStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource CardBorderStyle}" Margin="0">
                            <StackPanel>
                                <TextBlock Text="Controller Log" Style="{StaticResource SectionTitleStyle}"/>
                                <ListBox ItemsSource="{Binding ControllerLog}"
                                         Height="260"
                                         Margin="0,14,0,0"
                                         Background="#0C1728"
                                         BorderBrush="{StaticResource InputBorderBrush}"
                                         BorderThickness="1"
                                         Foreground="{StaticResource ValueBrush}"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         Padding="6"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
