<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RootNamespace>GRBL_Lathe_Control</RootNamespace>
    <AssemblyName>GRBL Sender</AssemblyName>
    <Product>GRBL Sender</Product>
    <Title>GRBL Sender</Title>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <Platforms>AnyCPU;x64</Platforms>
    <DefaultItemExcludes>$(DefaultItemExcludes);artifacts\**;bin\**;obj\**</DefaultItemExcludes>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="8.0.0" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="artifacts\**\*.cs;bin\**\*.cs;obj\**\*.cs" />
    <Page Remove="artifacts\**\*.xaml;bin\**\*.xaml;obj\**\*.xaml" />
    <ApplicationDefinition Remove="artifacts\**\App.xaml;bin\**\App.xaml;obj\**\App.xaml" />
    <EmbeddedResource Remove="artifacts\**;bin\**;obj\**" />
    <None Remove="artifacts\**;bin\**;obj\**" />
  </ItemGroup>

</Project>
